{
  "name": "project-action",
  "version": "1.2.2",
  "scripts": {
    "lint": "eslint src --max-warnings=0 --ext .ts",
    "lint:fix": "eslint src --max-warnings=0 --ext .ts --fix",
    "test": "mocha --require ./src/test/setup.cjs --require ts-node/register src/test/*.spec.ts",
    "build": "tsc",
    "release": "esbuild src/main/index.ts --bundle --platform=node --target=node24 --conditions=import --outfile=dist/index.js"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@ionos-deploy-now/actions-core": "^1.2.1",
    "axios": "^1.15.2",
    "axios-retry": "^4.5.0",
    "qs": "^6.15.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@ionos-deploy-now/eslint-config-actions": "^1.1.0",
    "@ionos-deploy-now/prettier-config-actions": "^1.1.0",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/qs": "^6.15.0",
    "@types/sinon": "^21.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "esbuild": "^0.25.0",
    "chai": "^4.5.0",
    "chai-as-promised": "^8.0.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-prettier": "^5.1.3",
    "mocha": "^12.0.0-beta-9.2",
    "prettier": "^3.2.5",
    "sinon": "^21.1.2",
    "ts-node": "^10.9.2",
    "ts-sinon": "^2.0.2",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0"
  },
  "engines": {
    "node": "^24.x"
  }
}
